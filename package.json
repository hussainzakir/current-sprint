{
  "name": "ui-bss-admin",
  "version": "1.0.0",
  "description": "Benefits Strategy Solutions Admin Apps",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o --host=ui-benefits-portal.hrpassport.com",
    "start:ext": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build --prod",
    "test": "ng test --code-coverage",
    "test:nomaps": "ng test --code-coverage --sourcemaps=false",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build:war": "ng build  --prod &&  cd dist && mkdir WEB-INF && cd .. && cp WEB-INF/* dist/WEB-INF && cd dist && jar -cf ui-bss-admin.war * && cd ../ && mkdir build && mv dist/ui-bss-admin.war build/",
    "build:jenkinsK8s": "npx ng build --prod",
    "build:jenkinsArtifactoryAndWar": "npx ng build  --prod &&  cd dist && mkdir WEB-INF && cd .. && cp WEB-INF/* dist/WEB-INF && cd dist && jar -cf ui-bss-admin.war * && cd ../ && mkdir build && mv dist/ui-bss-admin.war build/",
    "run:jenkinsRunNonE2EUnitTests": "npx ng test --progress=false --code-coverage --watch=false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://stash.trinet-devops.com/scm/leap/ui-bss-admin.git"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "11.2.14",
    "@angular/cdk": "11.2.13",
    "@angular/common": "11.2.14",
    "@angular/compiler": "11.2.14",
    "@angular/core": "11.2.14",
    "@angular/forms": "11.2.14",
    "@angular/localize": "11.2.14",
    "@angular/material": "11.2.13",
    "@angular/material-moment-adapter": "11.2.13",
    "@angular/platform-browser": "11.2.14",
    "@angular/platform-browser-dynamic": "11.2.14",
    "@angular/router": "11.2.14",
    "@ng-bootstrap/ng-bootstrap": "4.2.1",
    "@trinet/common": "9.0.14",
    "bootstrap": "4.3.1",
    "file-saver": "2.0.5",
    "moment": "2.24.0",
    "ngx-cookie": "5.0.0",
    "rxjs": "6.5.5",
    "tslib": "2.0.0",
    "zone.js": "0.10.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "0.1102.17",
    "@angular/cli": "11.2.17",
    "@angular/compiler-cli": "11.2.14",
    "@angular/language-service": "11.2.14",
    "@types/node": "12.11.1",
    "@types/jasmine": "3.6.0",
    "@types/jasminewd2": "2.0.3",
    "browser-sync": "2.26.14",
    "codelyzer": "6.0.0",
    "jasmine-core": "3.6.0",
    "jasmine-spec-reporter": "5.0.0",
    "karma": "6.3.10",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage-istanbul-reporter": "3.0.2",
    "karma-htmlfile-reporter": "0.3.8",
    "karma-jasmine": "4.0.0",
    "karma-jasmine-html-reporter": "1.5.0",
    "karma-sourcemap-loader": "0.3.7",
    "karma-verbose-reporter": "0.0.6",
    "protractor": "7.0.0",
    "ts-node": "7.0.0",
    "tslint": "6.1.0",
    "typescript": "4.0.8"
  }
}
